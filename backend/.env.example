# ─────────────────────────────────────────────
#  RoomYaaro — Backend Environment Variables
#  Copy this file to .env and fill in values.
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development
# Frontend origin — used for CORS and email reset links
CLIENT_URL=http://localhost:5173

# ── Database ─────────────────────────────────
# Neon (recommended): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# ── JWT ──────────────────────────────────────
# Use a long random string. Generate with: openssl rand -hex 64
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# ── AI — Google Gemini (primary engine) ──────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── AI — NVIDIA NIM (secondary, optional) ────
# Sign up at https://build.nvidia.com
# If set, NIM is tried first; Gemini is the fallback.
NVIDIA_API_KEY=
NVIDIA_MODEL=google/gemma-4-31b-it
NVIDIA_INVOKE_URL=https://integrate.api.nvidia.com/v1/chat/completions

# ── Email — SMTP ─────────────────────────────
# Brevo (recommended free tier): smtp-relay.brevo.com:587
# Gmail: smtp.gmail.com:587  (requires App Password if 2FA is on)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-api-key
EMAIL_FROM="RoomYaaro <no-reply@roomyaaro.com>"

# ── Cloudinary (image uploads) ───────────────
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Admin Seed ───────────────────────────────
# Used by: npm run db:seed
ADMIN_EMAIL=admin@roomyaaro.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Platform Admin
